generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  role         String     @default("client") // admin, client, developer
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  projects     Project[]  @relation("ClientProjects")
  files        ProjectFile[]
  comments     Comment[]
  activities   Activity[]
}

model Project {
  id           String        @id @default(uuid())
  title        String
  description  String?
  status       String        @default("pending") // pending, in-progress, completed
  clientId     String
  client       User          @relation("ClientProjects", fields: [clientId], references: [id])
  
  files        ProjectFile[]
  comments     Comment[]
  activities   Activity[]
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ProjectFile {
  id         String   @id @default(uuid())
  filename   String
  path       String
  uploadedAt DateTime @default(now())
  
  uploaderId String?
  uploader   User?    @relation(fields: [uploaderId], references: [id])
  
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
}

model Activity {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  
  action    String
  details   Json     @default("{}")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
